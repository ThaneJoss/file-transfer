{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "types": ["node", "vitest/globals", "@testing-library/jest-dom", "@playwright/test"]
  },
  "include": [
    "src",
    "src/test/**/*.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "tests/**/*.ts",
    "playwright.config.ts",
    "vitest.config.ts"
  ]
}
