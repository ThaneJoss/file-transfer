{
  "name": "file-transfer-station",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:worker": "wrangler dev",
    "build": "tsc -b && vite build && pnpm check:bundle",
    "build:worker": "tsc --noEmit -p worker/tsconfig.json",
    "preview": "vite preview --host 0.0.0.0",
    "preview:worker": "wrangler versions upload",
    "typecheck": "tsc -b && tsc --noEmit -p tsconfig.test.json",
    "check:worker": "tsc --noEmit -p worker/tsconfig.json",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:worker": "vitest run --config worker/vitest.config.ts",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "worker:types": "wrangler types worker/worker-configuration.d.ts --include-runtime=false",
    "worker:types:check": "wrangler types worker/worker-configuration.d.ts --include-runtime=false --check",
    "worker:dry-run": "wrangler deploy --dry-run",
    "deploy:worker": "pnpm db:migrations:apply:remote && wrangler deploy",
    "r2:cors:apply": "wrangler r2 bucket cors set \"$R2_BUCKET\" --file worker/config/r2-cors.json --force",
    "r2:cors:list": "wrangler r2 bucket cors list \"$R2_BUCKET\"",
    "db:generate": "drizzle-kit generate",
    "db:migrations:list:local": "wrangler d1 migrations list file-transfer-api-db --local",
    "db:migrations:list:remote": "wrangler d1 migrations list file-transfer-api-db --remote",
    "db:migrations:apply:local": "wrangler d1 migrations apply file-transfer-api-db --local",
    "db:migrations:apply:remote": "wrangler d1 migrations apply file-transfer-api-db --remote",
    "check": "pnpm typecheck && pnpm test:unit && pnpm test:e2e && pnpm build"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.19",
    "@better-auth/passkey": "1.6.19",
    "@noble/hashes": "2.2.0",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.19",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "jose": "^6.2.3",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.7",
    "@cloudflare/workers-types": "^5.20260723.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  }
}
